GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your_garmin_password
# Reuses Garmin OAuth tokens after completing MFA once
GARMIN_TOKEN_DIR=.garmin-tokens
# Optional Python executable override (default: py -3.13 on Windows, python3 elsewhere)
# GARMIN_PYTHON=C:\Path\To\python.exe
PORT=3000

# Set this to your ngrok public URL BEFORE connecting Claude.ai
# Run: ngrok http 3000
# Copy the https://xxxx.ngrok-free.app URL and paste here
PUBLIC_URL=https://xxxx.ngrok-free.app
